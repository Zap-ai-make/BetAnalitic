// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  username      String    @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  bio           String?

  // Verification
  emailVerified          DateTime?
  phoneVerified          DateTime?
  ageVerified            Boolean   @default(false)
  termsAcceptedAt        DateTime?
  riskDisclaimerAccepted Boolean   @default(false)

  // Subscription
  subscriptionTier  SubscriptionTier @default(FREE)
  subscriptionEndsAt DateTime?

  // User Preferences
  expertiseLevel  ExpertiseLevel @default(BEGINNER)
  favoriteSports  String[]       @default([])
  favoriteTeams   String[]       @default([])
  analysisDepth   AnalysisDepth  @default(STANDARD)
  language        String         @default("fr")

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?

  // Onboarding
  onboardingCompleted Boolean   @default(false)
  onboardingSkipped   Boolean   @default(false)
  userMode            UserMode  @default(ANALYTIC)

  // Tutorial
  tutorialCompleted   Boolean   @default(false)
  tutorialSkipped     Boolean   @default(false)
  firstAnalysisAt     DateTime?

  // Platform Tour
  tourCompleted       Boolean   @default(false)
  tourSkipped         Boolean   @default(false)

  // Account Deletion
  deletionScheduledAt DateTime?
  deletionReason      String?

  // Data Export
  lastExportAt        DateTime?

  // Relations
  sessions              Session[]
  verificationTokens    VerificationToken[]
  notificationPrefs     NotificationPreferences?
  agentConversations    AgentConversation[]
  agentMessages         AgentMessage[]
  agentFeedback         AgentFeedback[]

  @@index([email])
  @@index([phone])
  @@index([username])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  deviceName   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        String              @id @default(cuid())
  userId    String
  token     String              @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// ENUMS
// ============================================

enum SubscriptionTier {
  FREE
  PREMIUM
  EXPERT
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  MAGIC_LINK
}

enum ExpertiseLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum AnalysisDepth {
  QUICK
  STANDARD
  DETAILED
}

enum UserMode {
  ANALYTIC
  SUPPORTER
}

// ============================================
// NOTIFICATION PREFERENCES
// ============================================

model NotificationPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique

  // Global toggles
  pushEnabled   Boolean @default(true)
  emailDigest   EmailDigestFrequency @default(NONE)
  inAppAlerts   Boolean @default(true)

  // Do Not Disturb
  dndEnabled    Boolean @default(false)
  dndStart      String  @default("22:00")
  dndEnd        String  @default("08:00")

  // Per-agent notifications (JSON for flexibility)
  agentNotifications Json @default("{}")

  // Specific notification types
  matchAlerts   Boolean @default(true)
  agentAlerts   Boolean @default(true)
  weeklyDigest  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EmailDigestFrequency {
  NONE
  DAILY
  WEEKLY
}

// ============================================
// MATCH DATA
// ============================================

model Competition {
  id         String   @id @default(cuid())
  externalId String   @unique
  name       String
  country    String
  logoUrl    String?
  tier       Int      @default(1)
  season     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  matches    Match[]

  @@index([country])
  @@index([tier])
}

model Team {
  id         String   @id @default(cuid())
  externalId String   @unique
  name       String
  shortName  String
  logoUrl    String?
  country    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  @@index([name])
}

model Match {
  id            String      @id @default(cuid())
  externalId    String      @unique
  homeTeamId    String
  awayTeamId    String
  competitionId String
  kickoffTime   DateTime
  status        MatchStatus @default(SCHEDULED)
  homeScore     Int?
  awayScore     Int?

  // Metadata
  venue         String?
  referee       String?
  round         String?
  stage         String?

  // Additional data stored as JSON
  odds          Json?
  weather       Json?
  lineups       Json?
  statistics    Json?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  homeTeam           Team                  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam           Team                  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  competition        Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  tags               MatchTag[]
  precomputedData    PrecomputedMatchData?

  @@index([kickoffTime])
  @@index([status])
  @@index([competitionId])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchTag {
  id      String @id @default(cuid())
  matchId String
  tag     String // "Derby", "Clasico", "TopMatch", etc.

  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, tag])
  @@index([tag])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

model PrecomputedMatchData {
  id           String   @id @default(cuid())
  matchId      String   @unique

  // Aggregated data
  teamStats    Json     // Home/away team stats (form, goals, etc)
  h2hHistory   Json     // Head-to-head history
  referee      Json?    // Referee profile and stats
  weather      Json?    // Weather conditions

  // Metadata
  computedAt   DateTime @default(now())
  expiresAt    DateTime
  retryCount   Int      @default(0)
  lastError    String?

  // Relations
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([matchId])
}

// ============================================
// AI AGENTS
// ============================================

model AgentConversation {
  id          String   @id @default(cuid())
  userId      String
  agentType   AgentType
  title       String?
  matchId     String?
  roomId      String?
  isGuest     Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AgentMessage[]

  @@index([userId])
  @@index([agentType])
  @@index([matchId])
  @@index([createdAt])
}

model AgentMessage {
  id              String   @id @default(cuid())
  conversationId  String
  userId          String
  role            MessageRole
  content         String   @db.Text
  sources         Json?    // Array of sources/citations
  metadata        Json?    // Additional data (tokens, latency, etc)

  createdAt       DateTime @default(now())

  conversation    AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback        AgentFeedback?

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
}

model AgentFeedback {
  id          String   @id @default(cuid())
  messageId   String   @unique
  userId      String
  rating      FeedbackRating
  comment     String?

  createdAt   DateTime @default(now())

  message     AgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rating])
}

enum AgentType {
  SCOUT          // 🔍 DataScout
  FORM           // 📊 FormAnalyzer
  H2H            // ⚔️ HeadToHead
  STATS          // 📈 StatsMaster
  MOMENTUM       // 🌊 MomentumTracker
  CONTEXT        // 🧠 ContextKing
  ODDS           // 💰 OddsWhisperer
  WEATHER        // 🌦️ WeatherGuru
  REFEREE        // 🟨 RefereeWatch
  INJURY         // 🏥 InjuryAlert
  SENTIMENT      // 💬 SentimentPulse
  PREDICTION     // 🎯 PredictMaster
  RISK           // ⚠️ RiskGuardian
  VALUE          // 💎 ValueHunter
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

enum FeedbackRating {
  THUMBS_UP
  THUMBS_DOWN
}

// ============================================
// LEGACY (to be removed)
// ============================================

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
