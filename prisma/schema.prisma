// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id           String  @id @default(cuid())
  email        String? @unique
  phone        String? @unique
  username     String  @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  bio          String?

  // Verification
  emailVerified          DateTime?
  phoneVerified          DateTime?
  ageVerified            Boolean   @default(false)
  termsAcceptedAt        DateTime?
  riskDisclaimerAccepted Boolean   @default(false)

  // Subscription
  subscriptionTier   SubscriptionTier @default(FREE)
  subscriptionEndsAt DateTime?

  // User Preferences
  expertiseLevel ExpertiseLevel @default(BEGINNER)
  favoriteSports String[]       @default([])
  favoriteTeams  String[]       @default([])
  analysisDepth  AnalysisDepth  @default(STANDARD)
  language       String         @default("fr")

  // Metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Onboarding
  onboardingCompleted Boolean  @default(false)
  onboardingSkipped   Boolean  @default(false)
  userMode            UserMode @default(ANALYTIC)

  // Tutorial
  tutorialCompleted Boolean   @default(false)
  tutorialSkipped   Boolean   @default(false)
  firstAnalysisAt   DateTime?

  // Platform Tour
  tourCompleted Boolean @default(false)
  tourSkipped   Boolean @default(false)

  // Account Deletion
  deletionScheduledAt DateTime?
  deletionReason      String?

  // Data Export
  lastExportAt DateTime?

  // Relations
  sessions           Session[]
  verificationTokens VerificationToken[]
  notificationPrefs  NotificationPreferences?
  agentConversations AgentConversation[]
  agentMessages      AgentMessage[]
  agentFeedback      AgentFeedback[]

  // Room relations (Epic 6)
  ownedRooms      Room[]        @relation("RoomOwner")
  roomMemberships RoomMember[]  @relation("RoomMembership")
  roomMessages    RoomMessage[] @relation("RoomMessages")
  roomTickets     RoomTicket[]  @relation("RoomTickets")

  // Expert Program (Epic 10)
  expertApplication ExpertApplication?
  expertProfile     ExpertProfile?
  expertContent     ExpertContent[] // Story 10.5
  follows           ExpertFollow[]  @relation("UserFollows") // Story 10.6
  followers         ExpertFollow[]  @relation("ExpertFollowers") // Story 10.6
  subscriptions     ExpertSubscription[] @relation("UserSubscriptions") // Story 10.6
  subscribers       ExpertSubscription[] @relation("ExpertSubscribers") // Story 10.6
  payoutRequests    PayoutRequest[] @relation("ExpertPayouts") // Story 10.7

  @@index([email])
  @@index([phone])
  @@index([username])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  deviceName   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  token     String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// ENUMS
// ============================================

enum SubscriptionTier {
  FREE
  PREMIUM
  EXPERT
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  MAGIC_LINK
}

enum ExpertiseLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum AnalysisDepth {
  QUICK
  STANDARD
  DETAILED
}

enum UserMode {
  ANALYTIC
  SUPPORTER
}

// ============================================
// NOTIFICATION PREFERENCES
// ============================================

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Global toggles
  pushEnabled Boolean              @default(true)
  emailDigest EmailDigestFrequency @default(NONE)
  inAppAlerts Boolean              @default(true)

  // Do Not Disturb
  dndEnabled Boolean @default(false)
  dndStart   String  @default("22:00")
  dndEnd     String  @default("08:00")

  // Per-agent notifications (JSON for flexibility)
  agentNotifications Json @default("{}")

  // Specific notification types
  matchAlerts  Boolean @default(true)
  agentAlerts  Boolean @default(true)
  weeklyDigest Boolean @default(false)
  roomAlerts   Boolean @default(true) // Story 6.14: Room notifications

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EmailDigestFrequency {
  NONE
  DAILY
  WEEKLY
}

// ============================================
// MATCH DATA
// ============================================

model Competition {
  id         String  @id @default(cuid())
  externalId String  @unique
  name       String
  country    String
  logoUrl    String?
  tier       Int     @default(1)
  season     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]

  @@index([country])
  @@index([tier])
}

model Team {
  id         String  @id @default(cuid())
  externalId String  @unique
  name       String
  shortName  String
  logoUrl    String?
  country    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  @@index([name])
}

model Match {
  id            String      @id @default(cuid())
  externalId    String      @unique
  homeTeamId    String
  awayTeamId    String
  competitionId String
  kickoffTime   DateTime
  status        MatchStatus @default(SCHEDULED)
  homeScore     Int?
  awayScore     Int?

  // Metadata
  venue   String?
  referee String?
  round   String?
  stage   String?

  // Additional data stored as JSON
  odds       Json?
  weather    Json?
  lineups    Json?
  statistics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  homeTeam        Team                  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam        Team                  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  competition     Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  tags            MatchTag[]
  precomputedData PrecomputedMatchData?
  Room            Room[]

  @@index([kickoffTime])
  @@index([status])
  @@index([competitionId])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchTag {
  id      String @id @default(cuid())
  matchId String
  tag     String // "Derby", "Clasico", "TopMatch", etc.

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, tag])
  @@index([tag])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

model PrecomputedMatchData {
  id      String @id @default(cuid())
  matchId String @unique

  // Aggregated data
  teamStats  Json // Home/away team stats (form, goals, etc)
  h2hHistory Json // Head-to-head history
  referee    Json? // Referee profile and stats
  weather    Json? // Weather conditions

  // Metadata
  computedAt DateTime @default(now())
  expiresAt  DateTime
  retryCount Int      @default(0)
  lastError  String?

  // Relations
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([matchId])
}

// ============================================
// AI AGENTS
// ============================================

model AgentConversation {
  id        String    @id @default(cuid())
  userId    String
  agentType AgentType
  title     String?
  matchId   String?
  roomId    String?
  isGuest   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([userId])
  @@index([agentType])
  @@index([matchId])
  @@index([createdAt])
}

model AgentMessage {
  id             String      @id @default(cuid())
  conversationId String
  userId         String
  role           MessageRole
  content        String      @db.Text
  sources        Json? // Array of sources/citations
  metadata       Json? // Additional data (tokens, latency, etc)

  createdAt DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback     AgentFeedback?

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
}

model AgentFeedback {
  id        String         @id @default(cuid())
  messageId String         @unique
  userId    String
  rating    FeedbackRating
  comment   String?

  createdAt DateTime @default(now())

  message AgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rating])
}

enum AgentType {
  SCOUT // 🔍 DataScout
  FORM // 📊 FormAnalyzer
  H2H // ⚔️ HeadToHead
  STATS // 📈 StatsMaster
  MOMENTUM // 🌊 MomentumTracker
  CONTEXT // 🧠 ContextKing
  ODDS // 💰 OddsWhisperer
  WEATHER // 🌦️ WeatherGuru
  REFEREE // 🟨 RefereeWatch
  INJURY // 🏥 InjuryAlert
  SENTIMENT // 💬 SentimentPulse
  PREDICTION // 🎯 PredictMaster
  RISK // ⚠️ RiskGuardian
  VALUE // 💎 ValueHunter
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

enum FeedbackRating {
  THUMBS_UP
  THUMBS_DOWN
}

// ============================================
// COLLABORATIVE ROOMS (Epic 6)
// ============================================

model Room {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String  @default("#00D4FF")
  badge       String?

  visibility RoomVisibility @default(PUBLIC)
  type       RoomType       @default(PRIVATE)
  expertOnly Boolean        @default(false) // Story 10.8: Experts only
  expertHosted Boolean      @default(false) // Story 10.8: Hosted by verified expert

  ownerId String
  owner   User   @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)

  maxMembers Int @default(50)

  settings Json @default("{\"membersCanInvite\":true,\"membersCanInvokeAgents\":true,\"dataOnlyMode\":false}")

  members  RoomMember[]
  messages RoomMessage[]
  tickets  RoomTicket[]

  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  @@index([ownerId])
  @@index([matchId])
  @@index([createdAt])
  @@index([type, visibility])
}

model RoomMember {
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("RoomMembership", fields: [userId], references: [id], onDelete: Cascade)

  role     RoomRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@id([roomId, userId])
  @@index([userId])
  @@index([roomId, role])
}

model RoomMessage {
  id String @id @default(cuid())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("RoomMessages", fields: [userId], references: [id], onDelete: Cascade)

  type    RoomMessageType @default(TEXT)
  content String          @db.Text

  agentId   String?
  replyToId String?
  replyTo   RoomMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   RoomMessage[] @relation("MessageReplies")

  reactions Json?
  metadata  Json? // Story 6.10: Shared tickets, polls, etc.

  createdAt DateTime  @default(now())
  editedAt  DateTime?
  isDeleted Boolean   @default(false)

  @@index([roomId, createdAt])
  @@index([userId])
  @@index([agentId])
}

model RoomTicket {
  id String @id @default(cuid())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("RoomTickets", fields: [userId], references: [id], onDelete: Cascade)

  matches   Json // Array of match selections
  totalOdds Float

  status RoomTicketStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
  @@index([status])
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum RoomType {
  OFFICIAL
  PRIVATE
}

enum RoomRole {
  OWNER
  ADMIN
  MEMBER
}

enum RoomMessageType {
  TEXT
  AGENT
  SYSTEM
}

enum RoomTicketStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

// ============================================
// EXPERT PROGRAM (Epic 10)
// ============================================

model ExpertApplication {
  id     String @id @default(cuid())
  userId String @unique

  // Application Details
  bio               String
  expertiseAreas    String[] // e.g., ["Ligue 1", "Champions League", "xG Analysis"]
  socialProofLinks  String[] // LinkedIn, Twitter, blog, etc.
  trackRecord       String   // Description of past predictions/successes
  certifications    String?  // Optional certifications
  mediaAppearances  String?  // Optional media mentions

  // Review Process
  status        ExpertApplicationStatus @default(PENDING)
  submittedAt   DateTime                @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?                 // Admin userId
  rejectionReason String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([submittedAt])
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Expert Status
  verifiedAt     DateTime @default(now())
  verifiedBy     String   // Admin userId
  isActive       Boolean  @default(true)
  expertiseAreas String[] // Verified expertise areas

  // Performance Metrics
  followerCount    Int @default(0)
  subscriberCount  Int @default(0)
  contentCount     Int @default(0)
  totalRevenue     Float @default(0) // In euros
  platformRevenue  Float @default(0) // Platform's cut
  expertRevenue    Float @default(0) // Expert's cut

  // Content & Monetization
  monthlyPrice  Float? // Expert-set monthly subscription price
  yearlyPrice   Float? // Expert-set yearly subscription price
  isAcceptingSubs Boolean @default(false)

  // Payout Info
  stripeConnectId String? // Stripe Connect account ID
  payoutThreshold Float   @default(50.0)
  pendingPayout   Float   @default(0)
  totalPaidOut    Float   @default(0)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([followerCount])
}

// ============================================
// EXPERT CONTENT (Story 10.5)
// ============================================

model ExpertContent {
  id       String @id @default(cuid())
  authorId String

  // Content
  title       String
  content     String   @db.Text // Rich text content
  coverImage  String? // Optional cover image URL
  excerpt     String? // Short description
  tags        String[] // Content tags
  category    String? // Content category

  // Visibility & Access
  isPremium   Boolean @default(false) // Requires subscription to view
  isPublished Boolean @default(false) // Draft vs Published
  isDraft     Boolean @default(true)

  // Analytics
  viewCount    Int @default(0)
  likeCount    Int @default(0)
  commentCount Int @default(0)

  // Metadata
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([isPublished, isPremium])
  @@index([publishedAt])
}

enum ExpertApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// EXPERT FOLLOW & SUBSCRIPTION (Story 10.6)
// ============================================

model ExpertFollow {
  id         String   @id @default(cuid())
  userId     String   // Follower
  expertId   String   // Expert being followed
  followedAt DateTime @default(now())

  user   User @relation("UserFollows", fields: [userId], references: [id], onDelete: Cascade)
  expert User @relation("ExpertFollowers", fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([userId, expertId])
  @@index([userId])
  @@index([expertId])
}

model ExpertSubscription {
  id         String                @id @default(cuid())
  userId     String                // Subscriber
  expertId   String                // Expert
  status     SubscriptionStatus    @default(ACTIVE)
  plan       SubscriptionPlan      // MONTHLY or YEARLY
  price      Float                 // Price at time of subscription
  currency   String                @default("EUR")

  // Stripe
  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  // Dates
  startDate     DateTime  @default(now())
  currentPeriodEnd DateTime
  cancelAt      DateTime?
  canceledAt    DateTime?
  endedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  expert User @relation("ExpertSubscribers", fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([userId, expertId])
  @@index([userId])
  @@index([expertId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  PAUSED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

// ============================================
// EXPERT PAYOUTS (Story 10.7)
// ============================================

model PayoutRequest {
  id       String       @id @default(cuid())
  expertId String
  amount   Float
  currency String       @default("EUR")
  status   PayoutStatus @default(PENDING)

  // Stripe
  stripePayoutId String? @unique

  // Processing
  requestedAt DateTime  @default(now())
  processedAt DateTime?
  processedBy String? // Admin userId
  rejectedReason String?

  // Relations
  expert User @relation("ExpertPayouts", fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

// ============================================
// LEGACY (to be removed)
// ============================================

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
