# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/betanalytic"

# Auth.js (next-auth)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_TRUST_HOST=true

# Sportmonks API
# Get your API key from https://www.sportmonks.com/
SPORTMONKS_API_KEY="your-sportmonks-api-key-here"

# Cron Jobs
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# BetAnalytic API (VPS FastAPI)
BETANALYTIC_API_URL="https://api.srv1066171.hstgr.cloud"
BETANALYTIC_INTERNAL_SECRET="your-internal-secret-here"
BETANALYTIC_ADMIN_KEY="your-admin-key-here"
BETANALYTIC_JWT_SECRET="change-me-in-production"

# Ollama (Local fallback - optional, used when BetAnalytic is unavailable)
OLLAMA_BASE_URL="http://localhost:11434"

# Legacy OpenClaw (deprecated — remplacé par BetAnalytic)
# OPENCLAW_BASE_URL="http://your-vps-ip:8000"
# OPENCLAW_API_KEY="your-openclaw-api-key-here"

# Ably Real-time Messaging (Epic 6 - Collaborative Rooms)
# Get your API key from: https://ably.com/dashboard
# Create free account at: https://ably.com/signup
NEXT_PUBLIC_ABLY_KEY="your-ably-api-key-here"
